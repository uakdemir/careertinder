# JobHunter Secrets
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
APIFY_API_TOKEN=

# PostgreSQL connection (only needed if using driver: postgresql in config.yaml)
# Env vars override config.yaml values when set
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
